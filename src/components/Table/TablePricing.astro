	<table>
		<thead>
			<tr>
				<th>{metric}</th>
				{billing.map((item) => <th>{item}</th>)}
			</tr>
		</thead>
		<tbody>
			{
				Object.entries(transformedData).map(([tierName, prices]) => (
					<tr>
						<td class="whitespace-normal">
						{
							tierName.replace(/^#[^\s]+\s/, '')
						}
						</td>
						{
							Object.entries(prices).map((price) => {
								return (price[1] ? <td>{price[1]}</td> : null)
							})
						}
					</tr>
				))
			}
		</tbody>
	</table>
</div>
