///////////////
// FUNCTIONS //
///////////////

async function fetchPricingData() {	
	// product_slug come from Astro.props
  const response = await fetch(`https://vef4esszhdq.map.azionedge.net/api/pricing/get/product_slug/${product_slug}`);
  return await response.json();
}

function isReal() {
	// coin come from Astro.props
	return coin === 'real';
}

function formatPrice(value) {
	// Format price with proper decimal handling:
	// - 0.999 → 0.999 (keep significant decimals, don't round)
	// - 0.1640 → 0.164 (remove trailing zeros)
	// - 2.000 → 2.00 (ensure minimum 2 decimals)
	const numValue = parseFloat(value);
	if (isNaN(numValue)) return value;
	
	// Convert to string to check decimal places
	const strValue = String(value);
	
	// Check if value has decimal part
	if (strValue.includes('.')) {
		const decimalPart = strValue.split('.')[1] || '';
		// If has 2 or more decimal places, preserve them (removing trailing zeros)
		// but ensure at least 2 decimal places
		if (decimalPart.length >= 2) {
			// Remove trailing zeros but keep at least 2 decimals
			const formatted = numValue.toString();
			const parts = formatted.split('.');
			if (parts.length === 1) {
				// No decimal part after conversion, add .00
				return numValue.toFixed(2);
			}
			let decimals = parts[1];
			// If less than 2 decimals, pad with zeros
			if (decimals.length < 2) {
				return numValue.toFixed(2);
			}
			// Return as is (already has 2+ decimals)
			return formatted;
		}
	}
	// No decimals or only 1 decimal place - ensure 2 decimals
	return numValue.toFixed(2);
}

function normalizeRegionName(region) {
	const mappings = {
		'United States': 'USA',
		'All Other Regions': 'Other_Regions'
	};

	return mappings[region] || region.replace(' ', '_');
};

function transformData(data) {
  const tiers = {};
  const filteredData = data.filter(item => item.metric_slug === metric_slug);

	filteredData.forEach((item, index) => {
		const tiersCountry = {
			'USA': '',
			'Canada': '',
			'Europe': '',
			'Brazil': '',
			'Latam': '',
			'Other_Regions': ''
		};
		const tier = lang === 'pt-br' ? i18n[lang][item.tier_name] : item.tier_name;
    const region = normalizeRegionName(item.region);
		let price = '';
	
		if (item.brazilian_real_formatted || item.american_dollar_formatted) {
			price = isReal() ? item.brazilian_real_formatted : item.american_dollar_formatted;
		} else {
			price = isReal() ? item.brazilian_real : item.american_dollar
		}

		// Check if price is zero and replace with "Free"
		const numericPrice = isReal() ? item.brazilian_real : item.american_dollar;
		const formattedPrice = isReal() ? item.brazilian_real_formatted : item.american_dollar_formatted;
		const isZeroPrice = numericPrice === 0 || numericPrice === '0' || numericPrice === 0.0 || numericPrice === '0.00' ||
		                    parseFloat(numericPrice) === 0 ||
		                    formattedPrice === '0' || formattedPrice === '0.00' || formattedPrice === '0.000' ||
		                    parseFloat(formattedPrice) === 0;
		
		if (isZeroPrice) {
			// "Free" in English, "Grátis" in Portuguese
			price = lang === 'pt-br' ? 'Grátis' : 'Free';
		} else {
			// Normalize price to always have exactly 2 decimal places
			price = formatPrice(price);
			// Format for Brazilian Portuguese: use dot as thousand separator, comma as decimal separator
			// Example: 1000.00 -> 1.000,00
			// Applies to both Real (R$) and Dollar (USD) when lang is pt-br
			if(isReal() || lang === 'pt-br') {
				const parts = price.split('.');
				// Add thousand separators to the integer part
				if (parts[0].length > 3) {
					parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, '.');
				}
				// Join with comma as decimal separator
				price = parts.join(',');
			}
			// Format based on currency and language
			// R$ (Real) symbol on the left for Brazilian Real
			// $ (Dollar) symbol on the left for English, USD suffix for Portuguese
			if (isReal()) {
				price = `R$ ${price}`;
			} else if (lang === 'en') {
				price = `$${price}`;
			} else {
				price = `${price} USD`;
			}
		}

    if (!tiers[tier]) {
      tiers[tier] = tiersCountry;
    }

		// this validation is to when is the same tier but
		// should be repeated with another price
		// without this validation the last tier will replace the already setted
		const indexTier = `#${index} ${tier}`;
		if(tiers[tier][region]) {
			tiers[indexTier] = tiersCountry;
			tiers[indexTier][region] = price;
		} else {
			tiers[tier][region] = price;
		}
  });

  // Sort tiers: rows with zero prices (containing "Free" or "Grátis") come first
  return sortTiersByZeroPrice(tiers);
}

/**
 * Extracts the numeric price value from a formatted price string.
 * Handles formats like "0.999 USD", "R$ 0,999", "Free", "Grátis".
 * @param {string} price - The formatted price string
 * @returns {number} - The numeric price value
 */
function extractNumericPrice(price) {
	if (price === 'Free' || price === 'Grátis' || !price) {
		return 0;
	}
	// Remove currency symbols and extract number
	// Handles both "0.999 USD" and "R$ 0,999" formats
	const cleaned = price.replace(/[^\d.,]/g, '').replace(',', '.');
	return parseFloat(cleaned) || 0;
}

/**
 * Gets the minimum numeric price from a prices object for sorting purposes.
 * @param {Object} prices - The prices object with region keys
 * @returns {number} - The minimum numeric price found
 */
function getMinPrice(prices) {
	const priceValues = Object.values(prices)
		.filter(price => price) // Remove empty values
		.map(price => extractNumericPrice(price));
	
	return priceValues.length > 0 ? Math.min(...priceValues) : 0;
}

/**
 * Sorts the tiers object so that rows with zero prices appear first,
 * followed by non-zero price rows in descending order (highest price first).
 * A row is considered to have a zero price if any of its values is "Free" or "Grátis".
 * @param {Object} tiers - The unsorted tiers object
 * @returns {Object} - Sorted tiers object with zero-price rows first, then descending prices
 */
function sortTiersByZeroPrice(tiers) {
	const entries = Object.entries(tiers);
	
	// Separate entries into zero-price and non-zero-price
	const zeroPriceEntries = [];
	const nonZeroPriceEntries = [];
	
	entries.forEach(([tierName, prices]) => {
		// Check if any price in this row is "Free" or "Grátis"
		const hasZeroPrice = Object.values(prices).some(price =>
			price === 'Free' || price === 'Grátis'
		);
		
		if (hasZeroPrice) {
			zeroPriceEntries.push([tierName, prices]);
		} else {
			nonZeroPriceEntries.push([tierName, prices]);
		}
	});
	
	// Sort non-zero price entries in descending order (highest price first)
	nonZeroPriceEntries.sort((a, b) => {
		const minPriceA = getMinPrice(a[1]);
		const minPriceB = getMinPrice(b[1]);
		return minPriceB - minPriceA; // Descending order
	});
	
	// Combine: zero-price entries first, then sorted non-zero-price entries
	const sortedEntries = [...zeroPriceEntries, ...nonZeroPriceEntries];
	
	// Rebuild the object with sorted order
	const sortedTiers = {};
	sortedEntries.forEach(([tierName, prices]) => {
		sortedTiers[tierName] = prices;
	});
	
	return sortedTiers;
}


///////////
// EXEC //
/////////

const pricingData = await fetchPricingData();
const transformedData = transformData(pricingData);
