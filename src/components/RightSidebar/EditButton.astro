---
export interface Props {
	editHref: string;
}
import UIString from '../UIString.astro';
const { editHref } = Astro.props;
---
<ul class="flex flex-col gap-2">
	<li>
		<a
			class="text-color-secondary text-sm hover:underline"
			href="https://github.com/aziontech/docs/blob/main/README.md"
			target="_blank"
			data-tracking="github_docs"
			onclick="if(window.AzAnalytics?.trackClick) window.AzAnalytics.trackClick('right_sidebar', { href: this.href, text: 'Azion Docs', type: 'github_link' })"
		>
			<i class="pi pi-github mr-1"></i>
			Azion Docs
		</a>
	</li>
	<li>
		<a
			class="text-color-secondary text-sm hover:underline"
			href={editHref} target="_blank"
			data-tracking="edit_page"
			onclick="if(window.AzAnalytics?.trackClick) window.AzAnalytics.trackClick('right_sidebar', { href: this.href, text: 'Edit Page', type: 'contribute_link' })"
		>
			<i class="pi pi-pencil mr-1"></i>
			<UIString key="rightSidebar.editPage" />
		</a>
	</li>
</ul>
